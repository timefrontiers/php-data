{
  "name": "timefrontiers/php-data",
  "description": "PHP Data utilities - encryption, hashing, random generation",
  "keywords": ["php", "data", "encryption", "hashing", "random"],
  "homepage": "https://github.com/timefrontiers/php-data",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0",
  "authors": [
    {
      "name": "Time Frontiers Ltd",
      "email": "dev@timefrontiers.com",
      "homepage": "https://git.timefrontiers.com"
    },
    {
      "name": "Ikechukwu Okalia",
      "email": "consult@ikechukwuokalia.dev",
      "homepage": "https://ikechukwuokalia.dev"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-openssl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "TimeFrontiers\\Data\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TimeFrontiers\\Data\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  }
}
